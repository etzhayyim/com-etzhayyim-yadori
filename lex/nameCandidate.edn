{:lexicon 1
 :id "com.etzhayyim.yadori.nameCandidate"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :record
   {:type "object"
    :required ["fqdn" "charterClean" "squatClear" "createdAt"]
    :properties
    {:fqdn {:type "string"}
     :brief {:type "string" :description "the NL naming brief this candidate answers"}
     :charterClean {:type "boolean" :const true :description "G6 invariant — passed Charter-Rider §2(a)-(h) scan before surfacing"}
     :squatClear {:type "boolean" :const true :description "G6 invariant — cleared held-trademark + confusable screen; no speculation/parking"}
     :availability {:type "string" :enum ["available" "registered" "unknown"]}
     :rank {:type "integer" :minimum 0}
     :createdAt {:type "string" :format "datetime"}}}}}}
