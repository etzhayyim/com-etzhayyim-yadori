{:lexicon 1
 :id "com.etzhayyim.yadori.availabilityRecord"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :record
   {:type "object"
    :required ["fqdn" "availability" "source" "createdAt"]
    :properties
    {:fqdn {:type "string" :description "domain as supplied"}
     :asciiFqdn {:type "string" :description "IDNA/punycode-normalized form"}
     :tld {:type "string"}
     :availability {:type "string" :enum ["available" "registered" "unsupported-tld" "invalid" "rate-limited" "unknown"]}
     :rdapUrl {:type "string" :description "RDAP query URL (read-only, G1)"}
     :source {:type "string" :enum ["fixture" "live" "none"] :description "G8: live is operator-gated (G7)"}
     :representative {:type "boolean" :description "G8: true unless from a live RDAP fetch"}
     :createdAt {:type "string" :format "datetime"}}}}}}
