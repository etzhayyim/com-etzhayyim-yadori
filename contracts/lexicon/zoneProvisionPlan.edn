{:lexicon 1
 :id "com.etzhayyim.yadori.zoneProvisionPlan"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :record
   {:type "object"
    :required ["fqdn" "didwebTarget" "records" "planOnly" "createdAt"]
    :properties
    {:fqdn {:type "string"}
     :didwebTarget {:type "string" :description "did:web identifier this zone will anchor (ADR-2606013800)"}
     :records {:type "array"
               :description "DNS records the apex Worker needs (cutover pattern ADR-2605211757)"
               :items {:type "object"
                       :required ["type" "value"]
                       :properties {:type {:type "string" :enum ["A" "AAAA" "TXT" "CNAME" "MX" "NS"]}
                                    :name {:type "string"}
                                    :value {:type "string"}}}}
     :planOnly {:type "boolean" :const true :description "G7 invariant — no live zone write at R0; member-signed + operator-gated"}
     :prohibitedContentFree {:type "boolean" :const true :description "N5 — no DNS for prohibited content or detection-evasion (fast-flux/DGA/phishing)"}
     :createdAt {:type "string" :format "datetime"}}}}}}
