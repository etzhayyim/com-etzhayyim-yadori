{:lexicon 1
 :id "com.etzhayyim.yadori.registrarQuote"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :record
   {:type "object"
    :required ["fqdn" "registrar" "pricing" "createdAt"]
    :properties
    {:fqdn {:type "string"}
     :registrar {:type "string" :description "registrar id; default 'cloudflare' (G3)"}
     :pricing {:type "string" :enum ["at-cost" "low-markup" "markup"] :description "G3: default registrar is at-cost"}
     :councilGated {:type "boolean" :description "G3: true for external fiat-markup registrars"}
     :affiliateStripped {:type "boolean" :const true :description "affiliate/upsell/parking stripped by construction (mirrors okaimono strip_affiliate)"}
     :priceUsdMillis {:type "integer" :minimum 0 :description "DATA ONLY — informational; yadori is never the payer (G2)"}
     :createdAt {:type "string" :format "datetime"}}}}}}
