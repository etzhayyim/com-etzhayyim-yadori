{:cell/id "availability_check"
 :cell/glyph "宿"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/node "dan"
 :cell/doc "RDAP domain lookup → classify available / registered / unsupported-tld / invalid. Offline-default against a :representative IANA RDAP bootstrap + fixtures; live RDAP fetch is G7-gated (operator attestation + YADORI_ALLOW_LIVE_RDAP=1). Read-only (G1); no third-party zone enumeration. Wraps methods/availability.py."
 :cell/entry "src/yadori/cells/availability_check/state_machine.cljc"
 :cell/handler "AvailabilityCheckCell"
 :cell/state-graph
 {:nodes [:normalize :resolve-rdap :classify :availability-recorded] :entry :normalize
  :edges [[:normalize :resolve-rdap] [:resolve-rdap :classify] [:classify :availability-recorded] [:availability-recorded :end]]}
 :cell/llm {:provider :murakumo :endpoint "127.0.0.1:4000" :model "gemma3:4b" :charter-rider true}
 :cell/gates ["G1" "G7" "G8"]
 :cell/kotoba {:reads [:domain/fqdn] :writes [:domain/availability :domain/rdap-url]}}
