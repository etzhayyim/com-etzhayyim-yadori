{:cell/id "reservation"
 :cell/glyph "宿"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/node "asher"
 :cell/doc "The defining yadori cell: builds an UNSIGNED reservation intent (serverHeldKey=false) and authorizes it with a MEMBER signature only (server signature refused, G5). Member is registrant-of-record + payer via okaimono assisted-checkout (G2, ADR-2606012100); yadori never the buyer. Enforces no-squatting (G6) and registrar-default (G3) before intent. Live registrar mutate is G7-gated."
 :cell/entry "src/yadori/cells/reservation/state_machine.cljc"
 :cell/handler "ReservationCell"
 :cell/state-graph
 {:nodes [:screen :quote :intent-built :authorized] :entry :screen
  :edges [[:screen :quote] [:quote :intent-built] [:intent-built :authorized] [:authorized :end]]}
 :cell/llm {:provider :murakumo :endpoint "127.0.0.1:4000" :model "gemma3:4b" :charter-rider true}
 :cell/gates ["G2" "G3" "G5" "G6" "G7"]
 :cell/kotoba {:reads [:domain/fqdn :domain/availability :registrar/id] :writes [:domain/reservation-intent :domain/authorization]}}
