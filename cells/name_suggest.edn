{:cell/id "name_suggest"
 :cell/glyph "宿"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/node "naphtali"
 :cell/doc "NL brief → candidate domain names + cross-TLD alternatives when a name is taken. Murakumo-only (G4). Every candidate passes the Charter-Rider §2(a)-(h) scanner and the no-squatting eligibility screen (G6: held-trademark + confusable) BEFORE it is surfaced."
 :cell/state-graph
 {:nodes [:brief :generate :charter-scan :squat-screen :candidates-ranked] :entry :brief
  :edges [[:brief :generate] [:generate :charter-scan] [:charter-scan :squat-screen] [:squat-screen :candidates-ranked] [:candidates-ranked :end]]}
 :cell/llm {:provider :murakumo :endpoint "127.0.0.1:4000" :model "gemma3:4b" :charter-rider true}
 :cell/gates ["G4" "G6" "G8"]
 :cell/kotoba {:reads [:domain/brief :domain/availability] :writes [:domain/candidate]}}
